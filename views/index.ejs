<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Alpaca Strategy Lab</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="hero">
    <div>
      <p class="eyebrow">Paper trading only</p>
      <h1>Alpaca Strategy Lab</h1>
      <p class="muted">Local liquidity-sweep lab with paper-only automation, guardrails, journaling, and execution logs.</p>
    </div>
    <div class="badge <%= credsConfigured ? 'good' : 'warn' %>">
      <strong><%= credsConfigured ? 'Paper account connected' : 'No API creds yet' %></strong>
      <span>Live trading is not supported anywhere in this app.</span>
    </div>
  </header>

  <% if (success) { %><div class="flash success"><%= success %></div><% } %>
  <% if (error) { %><div class="flash error"><%= error %></div><% } %>
  <% if (errors?.length) { %><div class="flash error"><%= errors.join(' | ') %></div><% } %>

  <main class="grid">
    <section class="card wide stats-band">
      <div><span>Total ideas</span><strong><%= journalSummary.total %></strong></div>
      <div><span>Open workflows</span><strong><%= journalSummary.open %></strong></div>
      <div><span>Auto candidates</span><strong><%= automationCandidates.length %></strong></div>
      <div><span>Auto status</span><strong><%= automationSettings.enabled ? (automationSettings.autoSubmit ? 'Enabled + submit' : 'Enabled') : 'Disabled' %></strong></div>
      <div><span>Last automation run</span><strong><%= automationStatus.lastRunAt ? new Date(automationStatus.lastRunAt).toLocaleTimeString() : '—' %></strong></div>
      <div><span>Expectancy</span><strong><%= journalSummary.expectancyR !== null ? journalSummary.expectancyR + 'R' : '—' %></strong></div>
      <div><span>Open positions</span><strong><%= positions.length %></strong></div>
      <div><span>Open orders</span><strong><%= orders.length %></strong></div>
      <div><span>Legacy auto-submitted</span><strong><%= automationRisk.legacyAutoSubmittedCount %></strong></div>
    </section>

    <section class="card">
      <h2>Workflow state</h2>
      <div class="workflow-list">
        <% workflow.forEach((item) => { %>
          <article class="workflow-item">
            <div class="status-dot <%= item.status %>"></div>
            <div>
              <strong><%= item.label %></strong>
              <p class="muted"><%= item.detail %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="card">
      <h2>Paper account</h2>
      <% if (account) { %>
        <div class="stats">
          <div><span>Equity</span><strong>$<%= Number(account.equity).toFixed(2) %></strong></div>
          <div><span>Buying power</span><strong>$<%= Number(account.buying_power).toFixed(2) %></strong></div>
          <div><span>Status</span><strong><%= account.status %></strong></div>
          <div><span>Pattern day trader</span><strong><%= account.pattern_day_trader ? 'Yes' : 'No' %></strong></div>
        </div>
      <% } else { %>
        <p class="muted">Add <code>ALPACA_API_KEY</code> and <code>ALPACA_SECRET_KEY</code> to connect your paper account.</p>
      <% } %>
    </section>

    <section class="card wide">
      <div class="split-head">
        <h2>Automation controls</h2>
        <form action="/automation/run" method="post" class="inline-form compact-actions">
          <button type="submit">Run scan now</button>
        </form>
      </div>
      <div class="flash <%= automationSettings.autoSubmit ? 'error' : 'success' %>">
        <%= automationSettings.autoSubmit
          ? 'Auto-submit is currently ON. New qualifying automation signals can send paper bracket orders without manual review.'
          : 'Auto-submit is OFF. Automation can still scan and generate candidates, but it should not place new paper orders automatically.' %>
      </div>
      <div class="mini-note" style="margin-bottom: 12px; color: <%= automationSettings.autoSubmit ? '#b91c1c' : '#475569' %>;"><strong>Safety gate:</strong> turning on auto-submit now requires typing <code>ENABLE PAPER AUTO SUBMIT</code> before saving.</div>
      <div class="inline-form compact-actions" style="margin-bottom: 12px; gap: 8px;">
        <form action="/orders/cancel-open" method="post">
          <button type="submit">Cancel all open paper orders</button>
        </form>
        <form action="/positions/flatten" method="post">
          <button type="submit">Flatten all paper positions</button>
        </form>
      </div>
      <form action="/automation/settings" method="post" class="stack-form">
        <div class="three-col">
          <label class="checkbox-row"><input type="checkbox" name="enabled" value="1" <%= automationSettings.enabled ? 'checked' : '' %> /> Enable automation</label>
          <label class="checkbox-row"><input type="checkbox" name="autoSubmit" value="1" <%= automationSettings.autoSubmit ? 'checked' : '' %> /> Auto-place paper bracket orders</label>
          <label>Timeframe<select name="timeframe"><% automationTimeframes.forEach((timeframe) => { %><option value="<%= timeframe %>" <%= automationSettings.timeframe === timeframe ? 'selected' : '' %>><%= timeframe %></option><% }) %></select></label>
        </div>
        <div class="three-col">
          <label style="grid-column: span 2;">Type to confirm auto-submit<input type="text" name="autoSubmitConfirmText" placeholder="ENABLE PAPER AUTO SUBMIT" autocomplete="off" /></label>
        </div>
        <div class="three-col">
          <label>Poll every seconds<input type="number" name="pollIntervalSeconds" min="60" max="3600" value="<%= automationSettings.pollIntervalSeconds %>" /></label>
          <label>Lookback bars<input type="number" name="lookbackBars" min="6" max="100" value="<%= automationSettings.lookbackBars %>" /></label>
          <label>Signal window bars<input type="number" name="signalWindowBars" min="1" max="5" value="<%= automationSettings.signalWindowBars %>" /></label>
        </div>
        <div class="three-col">
          <label>Risk per trade ($)<input type="number" name="riskPerTrade" step="0.01" value="<%= automationSettings.riskPerTrade %>" /></label>
          <label>Watchlist cap<input type="number" name="maxWatchlistSymbols" min="1" max="30" value="<%= automationSettings.maxWatchlistSymbols %>" /></label>
          <label>Symbols per cycle<input type="number" name="symbolsPerCycle" min="1" max="30" value="<%= automationSettings.symbolsPerCycle || automationSettings.maxWatchlistSymbols %>" /></label>
        </div>
        <div class="three-col">
          <label>Min sweep % of price<input type="number" name="minSweepPercent" step="0.01" value="<%= automationSettings.minSweepPercent %>" /></label>
          <label>ETF min sweep %<input type="number" name="etfMinSweepPercent" step="0.01" value="<%= automationSettings.etfMinSweepPercent %>" /></label>
          <label>Min body/range ratio<input type="number" name="minBodyToRangeRatio" step="0.01" value="<%= automationSettings.minBodyToRangeRatio %>" /></label>
        </div>
        <div class="three-col">
          <label>Confirm body/range ratio<input type="number" name="confirmationBodyToRangeRatio" step="0.01" value="<%= automationSettings.confirmationBodyToRangeRatio %>" /></label>
          <label>Reward to risk<input type="number" name="rewardToRisk" step="0.1" value="<%= automationSettings.rewardToRisk %>" /></label>
          <label class="checkbox-row"><input type="checkbox" name="rotateWatchlist" value="1" <%= automationSettings.rotateWatchlist ? 'checked' : '' %> /> Rotate watchlist chunks across cycles</label>
        </div>
        <div class="three-col">
          <label>Max open positions<input type="number" name="maxOpenPositions" min="1" value="<%= automationSettings.maxOpenPositions %>" /></label>
          <label>Max open orders per symbol<input type="number" name="maxConcurrentOrdersPerSymbol" min="1" value="<%= automationSettings.maxConcurrentOrdersPerSymbol %>" /></label>
          <label>Stop buffer %<input type="number" name="stopBufferPercent" step="0.01" value="<%= automationSettings.stopBufferPercent %>" /></label>
        </div>
        <div class="three-col">
          <label>Take-profit buffer %<input type="number" name="takeProfitBufferPercent" step="0.01" value="<%= automationSettings.takeProfitBufferPercent %>" /></label>
          <label>Minimum price<input type="number" name="minimumPrice" step="0.01" value="<%= automationSettings.minimumPrice %>" /></label>
          <label>Maximum price<input type="number" name="maximumPrice" step="0.01" value="<%= automationSettings.maximumPrice %>" /></label>
        </div>
        <button type="submit">Save automation settings</button>
      </form>
      <p class="mini-note">Automation stays paper-only. It now checks the last few bars for sweep then reclaim/rejection confirmation, with slightly looser ETF thresholds and review-first defaults.</p>
      <div class="mini-note">One trade can create multiple visible Alpaca orders when brackets are used: an entry plus linked take-profit and stop-loss legs. So a burst of buy/sell rows does not always mean the strategy opened that many separate trades.</div>
      <div class="stats compact-stats top-gap">
        <div><span>Last summary</span><strong><%= automationStatus.lastSummary || '—' %></strong></div>
        <div><span>Runs</span><strong><%= automationStatus.runCount || 0 %></strong></div>
        <div><span>Last error</span><strong><%= automationStatus.lastError || 'None' %></strong></div>
        <div><span>Watchlist scope</span><strong><%= watchlist.length %> symbols</strong></div>
      </div>
      <% if (automationRisk.legacyAutoSubmittedCount > 0) { %>
        <div class="mini-note" style="margin-top: 10px; color: #b45309;">
          Warning: auto-submit is off now, but there are <strong><%= automationRisk.legacyAutoSubmittedCount %></strong> legacy auto-submitted journal entries from earlier runs across symbols like <strong><%= automationRisk.legacySymbols.join(', ') %></strong>.
        </div>
      <% } %>
    </section>

    <section class="card">
      <h2>Strategy rules</h2>
      <ol class="checklist">
        <% checklistItems.forEach((item) => { %>
          <li><%= item %></li>
        <% }) %>
      </ol>
      <div class="mini-note">Automation looks across the last few bars for a sweep, reclaim or rejection, and confirmation candle. It is still simple enough to inspect in the activity log.</div>
    </section>

    <section class="card">
      <h2>Risk sizing helper</h2>
      <form action="/" method="get" class="stack-form">
        <label>Symbol<input name="planSymbol" value="<%= plannerInput?.symbol || '' %>" placeholder="AAPL" /></label>
        <label>Side<select name="planSide"><option value="buy" <%= plannerInput?.side === 'buy' ? 'selected' : '' %>>Buy</option><option value="sell" <%= plannerInput?.side === 'sell' ? 'selected' : '' %>>Sell</option></select></label>
        <div class="two-col">
          <label>Entry price<input type="number" name="planEntryPrice" step="0.01" value="<%= plannerInput?.entryPrice || '' %>" required /></label>
          <label>Stop price<input type="number" name="planStopPrice" step="0.01" value="<%= plannerInput?.stopPrice || '' %>" required /></label>
        </div>
        <div class="two-col">
          <label>Target price<input type="number" name="planTargetPrice" step="0.01" value="<%= plannerInput?.targetPrice || '' %>" required /></label>
          <label>Risk budget ($)<input type="number" name="planRiskAmount" step="0.01" value="<%= plannerInput?.riskAmount || '' %>" required /></label>
        </div>
        <button type="submit">Calculate size</button>
      </form>
      <% if (plannerResult && !plannerResult.error) { %>
        <div class="planner-grid">
          <div><span>Shares</span><strong><%= plannerResult.qty %></strong></div>
          <div><span>Risk/share</span><strong>$<%= plannerResult.riskPerShare %></strong></div>
          <div><span>Reward/share</span><strong>$<%= plannerResult.rewardPerShare %></strong></div>
          <div><span>R multiple</span><strong><%= plannerResult.rewardToRisk %>R</strong></div>
          <div><span>Total risk</span><strong>$<%= plannerResult.totalRisk %></strong></div>
          <div><span>Notional</span><strong>$<%= plannerResult.notional %></strong></div>
        </div>
      <% } %>
    </section>

    <section class="card wide">
      <div class="split-head">
        <h2>Watchlist scope</h2>
        <form action="/watchlist" method="post" class="inline-form">
          <input type="text" name="watchlist" value="<%= watchlist.join(', ') %>" />
          <button type="submit">Save</button>
        </form>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Symbol</th><th>Last</th><th>Bid</th><th>Ask</th><th>Timestamp</th><th>Status</th></tr></thead>
          <tbody>
            <% if (watchQuotes.length) { watchQuotes.forEach((row) => { %>
              <tr>
                <td><strong><%= row.symbol %></strong></td>
                <td><%= row.last ? '$' + row.last.toFixed(2) : '—' %></td>
                <td><%= row.bid ? '$' + row.bid.toFixed(2) : '—' %></td>
                <td><%= row.ask ? '$' + row.ask.toFixed(2) : '—' %></td>
                <td><%= row.timestamp ? new Date(row.timestamp).toLocaleString() : '—' %></td>
                <td><%= row.error || 'OK' %></td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="6" class="muted">Watchlist data appears here once your paper API credentials are set.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Automation activity log</h2>
      <p class="mini-note">This log is the audit trail for scans. Deferred means intentionally skipped, blocked means guardrails stopped submission, candidate means reviewable setup found, and submitted means a paper order was sent.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Time</th><th>Symbol</th><th>Type</th><th>Detail</th></tr></thead>
          <tbody>
            <% if (automationStatus.activity?.length) { automationStatus.activity.forEach((item) => { %>
              <tr>
                <td><%= item.at ? new Date(item.at).toLocaleString() : '—' %></td>
                <td><%= item.symbol %></td>
                <td><span class="pill"><%= item.type %></span></td>
                <td><%= item.detail %></td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="4" class="muted">No automation activity yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Automation candidates</h2>
      <p class="mini-note">These are the most recent setups that survived the scan. The reason field is the strategy explanation for why the setup qualified.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Created</th><th>Symbol</th><th>Side</th><th>Entry</th><th>Stop</th><th>Target</th><th>Qty</th><th>Status</th><th>Why</th></tr></thead>
          <tbody>
            <% if (automationCandidates.length) { automationCandidates.forEach((candidate) => { %>
              <tr>
                <td><%= new Date(candidate.createdAt).toLocaleString() %></td>
                <td><%= candidate.symbol %></td>
                <td><%= candidate.side %></td>
                <td>$<%= candidate.entryPrice %></td>
                <td>$<%= candidate.stopPrice %></td>
                <td>$<%= candidate.targetPrice %></td>
                <td><%= candidate.qty %></td>
                <td><%= candidate.status %></td>
                <td><%= candidate.reason %></td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="9" class="muted">No automation candidates yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Open positions</h2>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Symbol</th><th>Side</th><th>Qty</th><th>Avg entry</th><th>Market value</th><th>Unrealized P/L</th><th>Actions</th></tr></thead>
          <tbody>
            <% if (positions.length) { positions.forEach((position) => { %>
              <tr>
                <td><%= position.symbol %></td>
                <td><%= Number(position.qty) >= 0 ? 'long' : 'short' %></td>
                <td><%= position.qty %></td>
                <td>$<%= Number(position.avg_entry_price).toFixed(2) %></td>
                <td>$<%= Number(position.market_value).toFixed(2) %></td>
                <td><%= Number(position.unrealized_pl).toFixed(2) %></td>
                <td>
                  <form action="/positions/flatten-symbol" method="post" class="inline-form compact-actions">
                    <input type="hidden" name="symbol" value="<%= position.symbol %>" />
                    <button type="submit">Flatten</button>
                  </form>
                </td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="7" class="muted">No open paper positions.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Position provenance</h2>
      <p class="mini-note">Shows the closest known journal/setup context for each currently open paper position.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Symbol</th><th>Source</th><th>Journal status</th><th>Entry</th><th>Stop</th><th>Target</th><th>Thesis</th></tr></thead>
          <tbody>
            <% if (positionProvenance.length) { positionProvenance.forEach((row) => { %>
              <tr>
                <td><%= row.symbol %></td>
                <td><%= row.strategy %></td>
                <td><%= row.journalStatus || '—' %></td>
                <td><%= row.entryPrice ? '$' + Number(row.entryPrice).toFixed(2) : '—' %></td>
                <td><%= row.stopPrice ? '$' + Number(row.stopPrice).toFixed(2) : '—' %></td>
                <td><%= row.targetPrice ? '$' + Number(row.targetPrice).toFixed(2) : '—' %></td>
                <td><%= row.thesis || 'No matching journal context found.' %></td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="7" class="muted">No open positions, so no provenance to show.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Open paper orders</h2>
      <p class="mini-note">These are order rows, not unique trade ideas. Bracket entries often fan out into linked exit legs, and replacements/cancels can add extra rows while still belonging to one setup.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Symbol</th><th>Side</th><th>Qty</th><th>Type</th><th>Status</th><th>Submitted</th><th>Actions</th></tr></thead>
          <tbody>
            <% if (orders.length) { orders.forEach((order) => { %>
              <tr>
                <td><%= order.symbol %></td>
                <td><%= order.side %></td>
                <td><%= order.qty %></td>
                <td><%= order.order_type %></td>
                <td><%= order.status %></td>
                <td><%= new Date(order.submitted_at).toLocaleString() %></td>
                <td>
                  <form action="/orders/cancel-symbol" method="post" class="inline-form compact-actions">
                    <input type="hidden" name="symbol" value="<%= order.symbol %>" />
                    <button type="submit">Cancel symbol orders</button>
                  </form>
                </td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="7" class="muted">No open paper orders.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card wide">
      <h2>Order diagnostics</h2>
      <p class="mini-note">Grouped by symbol so you can quickly see whether a symbol has a fresh entry, bracket exits, or a likely stale resting entry order.</p>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Symbol</th><th>Total</th><th>Entries</th><th>Take profits</th><th>Stops</th><th>Likely stale?</th></tr></thead>
          <tbody>
            <% if (orderDiagnostics.length) { orderDiagnostics.forEach((row) => { %>
              <tr>
                <td><%= row.symbol %></td>
                <td><%= row.count %></td>
                <td><%= row.entries %></td>
                <td><%= row.takeProfits %></td>
                <td><%= row.stopLosses %></td>
                <td><%= row.likelyStale ? 'yes' : 'no' %></td>
              </tr>
            <% }) } else { %>
              <tr><td colspan="6" class="muted">No open orders to diagnose.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="card">
      <h2>Pre-trade journal</h2>
      <form action="/journal" method="post" class="stack-form">
        <label>Symbol<input name="symbol" placeholder="AAPL" required /></label>
        <label>Side<select name="side"><option value="buy">Buy after sell-side sweep</option><option value="sell">Sell after buy-side sweep</option></select></label>
        <label>Liquidity level swept<input name="liquidityLevel" placeholder="Yesterday low / 5m equal lows" required /></label>
        <label>Trade thesis<textarea name="thesis" placeholder="Sweep of session low, reclaim, displacement, targeting range high" required></textarea></label>
        <label>Displacement evidence<input name="displacementSeen" placeholder="Strong candle close away from sweep" /></label>
        <label>Structure shift evidence<input name="structureShiftSeen" placeholder="5m MSS after reclaim" /></label>
        <div class="three-col">
          <label>Entry price<input type="number" name="entryPrice" step="0.01" required /></label>
          <label>Stop price<input type="number" name="stopPrice" step="0.01" required /></label>
          <label>Target price<input type="number" name="targetPrice" step="0.01" required /></label>
        </div>
        <div class="three-col">
          <label>Risk budget ($)<input type="number" name="riskAmount" step="0.01" placeholder="50" /></label>
          <label>Planned quantity<input type="number" name="plannedQty" step="1" min="1" placeholder="20" /></label>
          <label>Workflow state<select name="status"><% statusOptions.forEach((status) => { %><option value="<%= status %>"><%= status %></option><% }) %></select></label>
        </div>
        <label>Checklist score (0-6)<input type="number" name="checklistScore" min="0" max="6" value="4" required /></label>
        <label>Notes<textarea name="notes" placeholder="Context, invalidation, review reminders"></textarea></label>
        <button type="submit">Save setup to journal</button>
      </form>
    </section>

    <section class="card">
      <h2>Submit paper order</h2>
      <form action="/order" method="post" class="stack-form">
        <label>Symbol<input name="symbol" placeholder="AAPL" required /></label>
        <label>Side<select name="side"><option value="buy">Buy</option><option value="sell">Sell</option></select></label>
        <div class="two-col">
          <label>Quantity<input type="number" name="qty" step="1" min="1" required /></label>
          <label>Time in force<select name="timeInForce"><option value="day">Day</option><option value="gtc">GTC</option></select></label>
        </div>
        <label>Order type<select name="type"><option value="market">Market</option><option value="limit">Limit</option></select></label>
        <label>Limit price (if limit)<input type="number" name="limitPrice" step="0.01" /></label>
        <label class="checkbox-row"><input type="checkbox" name="useBracket" value="1" /> Add bracket exits</label>
        <div class="two-col">
          <label>Take-profit price<input type="number" name="takeProfitPrice" step="0.01" /></label>
          <label>Stop-loss price<input type="number" name="stopLossPrice" step="0.01" /></label>
        </div>
        <button type="submit">Send paper order to Alpaca</button>
      </form>
      <p class="mini-note">Still paper-only. Manual order entry remains available even if automation is off.</p>
    </section>

    <section class="card">
      <h2>Quick analytics</h2>
      <% if (journalSummary.topSymbols.length) { %>
        <div class="tag-list">
          <% journalSummary.topSymbols.forEach((symbol) => { %>
            <div class="tag-card">
              <strong><%= symbol.symbol %></strong>
              <span><%= symbol.count %> ideas</span>
              <span><%= symbol.winRate !== null ? symbol.winRate + '% win' : '—' %></span>
              <span><%= symbol.realizedR %>R</span>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="muted">Analytics fill in as you close out journal entries.</p>
      <% } %>
    </section>

    <section class="card wide">
      <h2>Journal</h2>
      <div class="journal-list">
        <% if (journal.length) { journal.forEach((entry) => { %>
          <article class="journal-entry">
            <div class="journal-top">
              <strong><%= entry.symbol %></strong>
              <span class="pill"><%= entry.side %></span>
              <span class="pill state-<%= entry.status %>"><%= entry.status %></span>
              <span>Score <%= entry.checklistScore %>/6</span>
              <span><%= new Date(entry.createdAt).toLocaleString() %></span>
            </div>
            <div class="journal-grid">
              <p><strong>Liquidity:</strong> <%= entry.liquidityLevel %></p>
              <p><strong>Prices:</strong> entry <%= entry.entryPrice %>, stop <%= entry.stopPrice %>, target <%= entry.targetPrice %></p>
              <p><strong>Plan:</strong> <%= entry.riskPerShare %>/share risk, <%= entry.plannedR || '—' %>R planned, qty <%= entry.plannedQty || '—' %></p>
              <p><strong>Budget:</strong> <%= entry.riskAmount ? '$' + entry.riskAmount : '—' %> risked</p>
              <p><strong>Displacement:</strong> <%= entry.displacementSeen || '—' %></p>
              <p><strong>Structure:</strong> <%= entry.structureShiftSeen || '—' %></p>
            </div>
            <p><strong>Thesis:</strong> <%= entry.thesis %></p>
            <% if (entry.notes) { %><p><strong>Notes:</strong> <%= entry.notes %></p><% } %>
            <% if (entry.outcomeNotes) { %><p><strong>Outcome:</strong> <%= entry.outcomeNotes %></p><% } %>

            <form action="/journal/<%= entry.id %>/review" method="post" class="review-form">
              <label>Status
                <select name="status">
                  <% statusOptions.forEach((status) => { %>
                    <option value="<%= status %>" <%= entry.status === status ? 'selected' : '' %>><%= status %></option>
                  <% }) %>
                </select>
              </label>
              <label>Realized R
                <input type="number" name="realizedR" step="0.01" value="<%= entry.realizedR ?? '' %>" placeholder="1.5" />
              </label>
              <label class="grow">Review note
                <input type="text" name="outcomeNotes" value="<%= entry.outcomeNotes || '' %>" placeholder="Why it worked, failed, or got scratched" />
              </label>
              <button type="submit">Update review</button>
            </form>
          </article>
        <% }) } else { %>
          <p class="muted">No journal entries yet. Log the setup before you click submit.</p>
        <% } %>
      </div>
    </section>
  </main>
</body>
</html>
